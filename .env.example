# Copy to .env and fill in. .env is git-ignored and must never be committed.

# Hugging Face access token (https://huggingface.co/settings/tokens).
HF_KEY="your_hf_token_here"

# Where models are cached / downloaded (download_models.py writes
# <cache>/<org>__<name> here, plus model_paths.json).
HF_CACHE_DIR="/path/to/huggingface/hub"
MODEL_CACHE_DIR="/path/to/huggingface/hub"

# Optional: directory of the training virtualenv's bin/ (so the shell scripts
# can find python / torchrun / llamafactory-cli). Leave unset to use PATH.
TRAINER_BIN="/path/to/venv/bin"

# Raw inputs for build_sft_data.py (external to this repo).
RAW_SFT_PATH="/path/to/sft_examples.json"
METADATA_DIR="/path/to/deepseek_listwise_metadata_dir"
